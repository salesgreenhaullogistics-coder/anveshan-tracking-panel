# Filflo Bot Environment Variables
# Copy this file to .env and fill in your actual values.
# NEVER commit the .env file to Git.

# Filflo Portal Login
FILFLO_LOGIN_EMAIL=your_email@anveshan.farm
FILFLO_LOGIN_PASSWORD=your_password_here

# (Optional) Override default bot folder path
# FILFLO_BOT_FOLDER=C:\Users\yourname\Desktop\Filflo_Bot

# Gmail SMTP (for sending reports)
FILFLO_GMAIL_SENDER=your_email@anveshan.farm
FILFLO_GMAIL_APP_PASSWORD=your_gmail_app_password
FILFLO_EMAIL_RECIPIENT=recipient1@anveshan.farm,recipient2@anveshan.farm

# Google Sheets
FILFLO_GOOGLE_SHEET_ID=your_google_sheet_id_here
FILFLO_GOOGLE_WORKSHEET_NAME=Sheet1
FILFLO_GOOGLE_SHEET_ID_2=
FILFLO_GOOGLE_WORKSHEET_NAME_2=Sheet1
FILFLO_SYNC_DOWNLOAD_TO_GSHEET=true

# LLM Backend (groq or openai)
FILFLO_LLM_BACKEND=groq
GROQ_API_KEY=your_groq_api_key_here
# OPENAI_API_KEY=your_openai_key_here

# Scootsy DN Updation (Gmail IMAP)
SCOOTSY_GMAIL_USER=marketplace@anveshan.farm
SCOOTSY_GMAIL_APP_PASSWORD=your_scootsy_app_password
SCOOTSY_SPREADSHEET_ID=your_scootsy_google_sheet_id
SCOOTSY_WORKSHEET_GID=
SCOOTSY_WORKSHEET_NAME=
SCOOTSY_SUBJECT_PATTERN=Purchase Return
SCOOTSY_LOOKBACK_DAYS=30
SCOOTSY_SEEN_REGISTER_PATH=
SCOOTSY_FORWARD_RECIPIENT=nandlal@anveshan.farm

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
# TELEGRAM_ALLOWED_USERS=123456,789012

# Slack Bridge for Filflo Chat
FILFLO_SLACK_ENABLED=false
FILFLO_SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
# Optional but recommended for Socket Mode + confirmation buttons
FILFLO_SLACK_APP_TOKEN=xapp-your-slack-app-token
FILFLO_SLACK_ALLOWED_USER_IDS=U0123456789
FILFLO_SLACK_ALLOWED_CHANNEL_IDS=
FILFLO_SLACK_POLL_SECONDS=15
FILFLO_SLACK_COMMAND_PREFIX=filflo:
FILFLO_SLACK_REPLY_IN_THREAD=true

# Instamart Playwright bot variables now live in:
# instamart-playwright-bot/.env.example
